# Images (not useful as text context)
**/*.jpg
**/*.jpeg
**/*.png
**/*.gif
**/*.bmp
**/*.webp

# PCB binary outputs (future)
**/*.gbr
**/*.drl
**/*.gerber

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/.venv/
**/venv/

# Node.js (future MCP servers)
**/node_modules/

